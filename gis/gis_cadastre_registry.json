    "ogc_api_pattern": "GET {base_url}/collections/{collection}/items?f=json&bbox={lon_min},{lat_min},{lon_max},{lat_max}&limit={limit}&offset={offset}",
    "wfs_pattern": "GET {base_url}?SERVICE=WFS&VERSION=2.0.0&REQUEST=GetFeature&TYPENAMES={layer}&SRSNAME=EPSG:4326&BBOX={lon_min},{lat_min},{lon_max},{lat_max}&outputFormat=application/json"
  },
  "access_tiers": {
    "open": "Free, no registration, machine-readable API",
