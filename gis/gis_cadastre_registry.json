          "query_example": "[out:json];(way[landuse]({{bbox}});relation[landuse]({{bbox}}));out geom;",
          "notes": "Best for urban land use. Rural parcel coverage is poor in most countries.",
          "docs": "https://overpass-api.de"
        },
        {
          "name": "World Bank — Land Portal",
          "type": "bulk_download",
          "access": "open",
