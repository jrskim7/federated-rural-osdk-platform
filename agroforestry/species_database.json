  "metadata": {
    "version": "1.0.0",
    "created": "2026-04-25",
    "maintainer": "JRBD / Conscious Circle / Federated OSDK Platform",
    "description": "Global species database for the OSDK Agroforestry Design Module. Each species carries attributes for stratification, ecological role, site suitability, guild compatibility, DEXi evaluation scores (where available), production traits, and implementation parameters. Designed for use in the permaculture design workflow: GIS site assessment → species selection → stratification composer → BOM/MEL export.",
    "reference_case": "Montalma / Monte da Fóia, Monchique, Portugal (south-facing, 30-40°, 400-900m altitude, 1000-2000mm rainfall, foíte bedrock)",
    "sources": [
      "Nature Plants 2024 — Native Plants for Greening Mediterranean Agroecosystems (Zenodo:3460431)",
      "LIFE AgroForAdapt (LIFE20 CCA/ES/001682) — agroforadapt.eu",
      "Danyadara Syntropic Agroforestry project, Andalusia — danyadara.com",
      "Iberian Agroforestry Pioneers Network — resilience-blog.com (EFI/LIFE)",
      "Attached field data: Species_data.xlsx, DEXi_file_for_species_evaluation.dxi",
      "PRIMA 2024 — Most Important Fruit Crops in the Mediterranean Basin (UniMilano)",
      "Cal Poly Demonstration Orchard thesis 2023",
      "JRBD field observation + Montalma inventory (2025-2026)"
    ]
  },

  "strata": {
    "E": "Emergent / tall canopy (>10m)",
    "C": "Canopy (5-10m)",
    "U": "Understory / sub-canopy (2-5m)",
    "S": "Shrub layer (0.5-2m)",
    "H": "Herbaceous / ground cover (<0.5m)",
    "G": "Ground cover / creeping",
    "V": "Vine / climber",
    "R": "Rhizosphere / root crops"
  },

  "ecological_roles": {
    "N_FIX": "Nitrogen fixer",
    "DYN_ACC": "Dynamic accumulator (deep root nutrient miner)",
    "POLL": "Pollinator attractor",
    "PEST_REP": "Pest repellent",
    "WIND": "Windbreak / shelter",
    "EROSION": "Erosion control",
    "MULCH": "Chop-and-drop biomass",
    "NURSE": "Nurse plant (shade/shelter for establishing species)",
    "CASH_FRUIT": "Cash crop — fruit/nut",
    "CASH_VEG": "Cash crop — vegetable",
    "CASH_HERB": "Cash crop — aromatic/medicinal",
    "CASH_SEED": "Cash crop — seed production",
    "BIOMASS": "Biomass / fodder",
    "SOIL_STAB": "Soil stabilisation",
    "LIVING_MULCH": "Living mulch",
    "PEST_HOST": "Beneficial insect / pest host plant"
  },

  "dexi_attributes": {
    "suitability_index": "Overall DEXi suitability",
